{
  "openapi": "3.0.0",
  "info": {
    "title": "Imago API",
    "version": "1.0.0",
    "description": "Media search API for IMAGO content library"
  },
  "servers": [
    {
      "url": "http://localhost:3000/api",
      "description": "Local server"
    }
  ],
  "paths": {
    "/analytics": {
      "get": {
        "operationId": "get-analytics",
        "summary": "Get search analytics",
        "description": "Returns aggregated analytics: total searches, average response time, and top keywords.",
        "tags": [
          "Analytics"
        ],
        "parameters": [
          {
            "in": "query",
            "name": "topN",
            "schema": {
              "type": "integer",
              "description": "Number of top queries to return"
            },
            "required": false,
            "description": "Number of top queries to return"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AnalyticsResponse"
                }
              }
            }
          }
        }
      }
    },
    "/media/facets": {
      "get": {
        "operationId": "get-media-facets",
        "summary": "Get filter facets",
        "description": "Returns available filter options (credits, restrictions, date range) for the search UI.",
        "tags": [
          "Media"
        ],
        "parameters": [],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FacetsResponse"
                }
              }
            }
          }
        }
      }
    },
    "/media/search": {
      "get": {
        "operationId": "get-media-search",
        "summary": "Search media items",
        "description": "Search across media items with keyword matching, filters, sorting, and pagination.",
        "tags": [
          "Media"
        ],
        "parameters": [
          {
            "in": "query",
            "name": "query",
            "schema": {
              "type": "string",
              "description": "Search query"
            },
            "required": false,
            "description": "Search query"
          },
          {
            "in": "query",
            "name": "credit",
            "schema": {
              "type": "string",
              "description": "Filter by credit/photographer"
            },
            "required": false,
            "description": "Filter by credit/photographer"
          },
          {
            "in": "query",
            "name": "dateFrom",
            "schema": {
              "type": "string",
              "description": "Filter from date (YYYY-MM-DD)"
            },
            "required": false,
            "description": "Filter from date (YYYY-MM-DD)"
          },
          {
            "in": "query",
            "name": "dateTo",
            "schema": {
              "type": "string",
              "description": "Filter to date (YYYY-MM-DD)"
            },
            "required": false,
            "description": "Filter to date (YYYY-MM-DD)"
          },
          {
            "in": "query",
            "name": "restrictions",
            "schema": {
              "type": "array",
              "description": "Filter by restriction country codes"
            },
            "required": false,
            "description": "Filter by restriction country codes"
          },
          {
            "in": "query",
            "name": "sortBy",
            "schema": {
              "type": "string",
              "enum": [
                "relevance",
                "date_asc",
                "date_desc"
              ],
              "description": "Sort order"
            },
            "required": false,
            "description": "Sort order"
          },
          {
            "in": "query",
            "name": "page",
            "schema": {
              "type": "integer",
              "description": "Page number"
            },
            "required": false,
            "description": "Page number"
          },
          {
            "in": "query",
            "name": "pageSize",
            "schema": {
              "type": "integer",
              "description": "Items per page"
            },
            "required": false,
            "description": "Items per page"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AnalyticsQueryParams": {
        "type": "object",
        "properties": {
          "topN": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "description": "Number of top queries to return"
          }
        }
      },
      "AnalyticsResponse": {
        "type": "object",
        "properties": {
          "totalSearches": {
            "type": "integer",
            "description": "Total number of searches performed"
          },
          "avgResponseTimeMs": {
            "type": "number",
            "description": "Average response time in milliseconds"
          },
          "topQueries": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "query": {
                  "type": "string",
                  "description": "Original search query"
                },
                "count": {
                  "type": "integer",
                  "description": "Number of times this query was searched"
                },
                "matchedTokens": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "description": "Index tokens that matched the query"
                },
                "avgResponseTimeMs": {
                  "type": "number",
                  "description": "Average response time for this query in milliseconds"
                }
              },
              "required": [
                "query",
                "count",
                "matchedTokens",
                "avgResponseTimeMs"
              ]
            },
            "description": "Most frequently searched queries"
          }
        },
        "required": [
          "totalSearches",
          "avgResponseTimeMs",
          "topQueries"
        ]
      },
      "FacetsResponse": {
        "type": "object",
        "properties": {
          "credits": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Available photographer/agency names"
          },
          "restrictions": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Available restriction country codes"
          },
          "dateRange": {
            "type": "object",
            "properties": {
              "min": {
                "type": "string",
                "description": "Earliest date (YYYY-MM-DD)"
              },
              "max": {
                "type": "string",
                "description": "Latest date (YYYY-MM-DD)"
              }
            },
            "required": [
              "min",
              "max"
            ],
            "description": "Date range bounds"
          }
        },
        "required": [
          "credits",
          "restrictions",
          "dateRange"
        ]
      },
      "SearchQueryParams": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "Search query"
          },
          "credit": {
            "type": "string",
            "description": "Filter by credit/photographer"
          },
          "dateFrom": {
            "type": "string",
            "description": "Filter from date (YYYY-MM-DD)"
          },
          "dateTo": {
            "type": "string",
            "description": "Filter to date (YYYY-MM-DD)"
          },
          "restrictions": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Filter by restriction country codes"
          },
          "sortBy": {
            "type": "string",
            "enum": [
              "relevance",
              "date_asc",
              "date_desc"
            ],
            "description": "Sort order"
          },
          "page": {
            "type": "integer",
            "minimum": 1,
            "description": "Page number"
          },
          "pageSize": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "description": "Items per page"
          }
        },
        "required": [
          "query"
        ]
      },
      "SearchResponse": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MediaItemSchema"
            },
            "description": "Matching media items"
          },
          "page": {
            "type": "integer",
            "description": "Current page"
          },
          "pageSize": {
            "type": "integer",
            "description": "Items per page"
          },
          "total": {
            "type": "integer",
            "description": "Total matching items"
          },
          "totalPages": {
            "type": "integer",
            "description": "Total pages"
          }
        },
        "required": [
          "items",
          "page",
          "pageSize",
          "total",
          "totalPages"
        ]
      },
      "AnalyticsQuery": {
        "type": "object",
        "properties": {
          "topN": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "description": "Number of top queries to return"
          }
        }
      },
      "MediaItemSchema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier (bildnummer)"
          },
          "imageNumber": {
            "type": "string",
            "description": "Image number"
          },
          "description": {
            "type": "string",
            "description": "Normalized description text"
          },
          "rawDescription": {
            "type": "string",
            "description": "Original suchtext"
          },
          "credit": {
            "type": "string",
            "description": "Photographer/agency"
          },
          "date": {
            "type": "string",
            "description": "ISO date (YYYY-MM-DD)"
          },
          "rawDate": {
            "type": "string",
            "description": "Original date (DD.MM.YYYY)"
          },
          "restrictions": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Restriction country codes"
          },
          "width": {
            "type": "number",
            "description": "Image width in pixels"
          },
          "height": {
            "type": "number",
            "description": "Image height in pixels"
          }
        },
        "required": [
          "id",
          "imageNumber",
          "description",
          "rawDescription",
          "credit",
          "date",
          "rawDate",
          "restrictions",
          "width",
          "height"
        ]
      },
      "SearchQuery": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "Search query"
          },
          "credit": {
            "type": "string",
            "description": "Filter by credit/photographer"
          },
          "dateFrom": {
            "type": "string",
            "description": "Filter from date (YYYY-MM-DD)"
          },
          "dateTo": {
            "type": "string",
            "description": "Filter to date (YYYY-MM-DD)"
          },
          "restrictions": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Filter by restriction country codes"
          },
          "sortBy": {
            "type": "string",
            "enum": [
              "relevance",
              "date_asc",
              "date_desc"
            ],
            "description": "Sort order"
          },
          "page": {
            "type": "integer",
            "minimum": 1,
            "description": "Page number"
          },
          "pageSize": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "description": "Items per page"
          }
        },
        "required": [
          "query"
        ]
      },
      "MediaItem": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier (bildnummer)"
          },
          "imageNumber": {
            "type": "string",
            "description": "Image number"
          },
          "description": {
            "type": "string",
            "description": "Normalized description text"
          },
          "rawDescription": {
            "type": "string",
            "description": "Original suchtext"
          },
          "credit": {
            "type": "string",
            "description": "Photographer/agency"
          },
          "date": {
            "type": "string",
            "description": "ISO date (YYYY-MM-DD)"
          },
          "rawDate": {
            "type": "string",
            "description": "Original date (DD.MM.YYYY)"
          },
          "restrictions": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Restriction country codes"
          },
          "width": {
            "type": "number",
            "description": "Image width in pixels"
          },
          "height": {
            "type": "number",
            "description": "Image height in pixels"
          }
        },
        "required": [
          "id",
          "imageNumber",
          "description",
          "rawDescription",
          "credit",
          "date",
          "rawDate",
          "restrictions",
          "width",
          "height"
        ]
      },
      "SearchResult": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MediaItemSchema"
            },
            "description": "Matching media items"
          },
          "page": {
            "type": "integer",
            "description": "Current page"
          },
          "pageSize": {
            "type": "integer",
            "description": "Items per page"
          },
          "total": {
            "type": "integer",
            "description": "Total matching items"
          },
          "totalPages": {
            "type": "integer",
            "description": "Total pages"
          }
        },
        "required": [
          "items",
          "page",
          "pageSize",
          "total",
          "totalPages"
        ]
      }
    },
    "responses": {}
  }
}